FROM maven:3.9-eclipse-temurin-21 AS build
WORKDIR /build
COPY pom.xml .
COPY microservice-configServer/pom.xml microservice-configServer/pom.xml
COPY microservice-configServer/src microservice-configServer/src
RUN mvn clean package -DskipTests -f microservice-configServer/pom.xml

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY --from=build /build/microservice-configServer/target/*.jar app.jar
EXPOSE 8888
ENTRYPOINT ["java", "-jar", "app.jar"]