FROM maven:3.9-eclipse-temurin-21 AS build
WORKDIR /build
COPY pom.xml .
COPY microservice-security/pom.xml microservice-security/pom.xml
COPY microservice-security/src microservice-security/src
RUN mvn clean package -DskipTests -f microservice-security/pom.xml

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY --from=build /build/microservice-security/target/*.jar app.jar
EXPOSE 9001
ENTRYPOINT ["java", "-jar", "app.jar"]