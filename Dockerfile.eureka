FROM maven:3.9-eclipse-temurin-21 AS build
WORKDIR /build
COPY pom.xml .
COPY microservice-eureka/pom.xml microservice-eureka/pom.xml
COPY microservice-eureka/src microservice-eureka/src
RUN mvn clean package -DskipTests -f microservice-eureka/pom.xml

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY --from=build /build/microservice-eureka/target/*.jar app.jar
EXPOSE 8761
ENTRYPOINT ["java", "-jar", "app.jar"]